<UserControl x:Class="YangzaiWorkshop.Views.AudioPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 小说选择 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}"
                Padding="10,8" Margin="0,0,0,8">
            <ScrollViewer x:Name="NovelScroller"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="NovelScroller_MouseWheel">
                <WrapPanel x:Name="NovelCardPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- 章节导航 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 全局音频按钮（独立于章节列表） -->
                <Button x:Name="GlobalAudioBtn" Grid.Column="0"
                        Content="📁 全局音频"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="12" Padding="10,6" MinHeight="28"
                        Margin="0,0,8,0"
                        Click="GlobalAudioBtn_Click"/>
                <ScrollViewer x:Name="ChapterTabsScroller" Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="ChapterTabsScroller_PreviewMouseWheel">
                    <StackPanel x:Name="ChapterTabsPanel" Orientation="Horizontal"/>
                </ScrollViewer>
                <Button x:Name="ChapterExpandBtn" Grid.Column="2"
                        Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                        FontSize="13" MinWidth="28" MinHeight="28"
                        Margin="4,0,0,0" Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="ChapterExpandBtn_Click" ToolTip="展开章节列表"/>
            </Grid>
        </Border>

        <!-- 章节弹窗 -->
        <Popup x:Name="ChapterPopup" PlacementTarget="{Binding ElementName=ChapterExpandBtn}"
               Placement="Bottom" StaysOpen="False"
               AllowsTransparency="True" PopupAnimation="Slide">
            <Border x:Name="ChapterPopupBorder" CornerRadius="8"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MaxHeight="400" MinWidth="400">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <UniformGrid x:Name="ChapterPopupList" Columns="4" Margin="4"/>
                </ScrollViewer>
            </Border>
        </Popup>

        <!-- 音频区域（卡片网格） -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              AllowDrop="True"
                              Drop="AudioGrid_Drop" DragOver="AudioGrid_DragOver">
                    <StackPanel x:Name="AudioGrid"/>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="+ 导入音频" Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="12" Padding="10,6"
                            Click="ImportAudio_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toast -->
        <Border x:Name="ToastBorder" Grid.RowSpan="3"
                Background="#E0333333" CornerRadius="8" Padding="14,8"
                Opacity="0" HorizontalAlignment="Center"
                VerticalAlignment="Bottom" Margin="0,0,0,20"
                IsHitTestVisible="False">
            <TextBlock x:Name="ToastText" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
