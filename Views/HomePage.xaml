<UserControl x:Class="YangzaiWorkshop.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <!-- 轮播区 : 下半区 ≈ 5 : 3，随窗口等比缩放 -->
            <RowDefinition Height="5*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- ===== 轮播视频（RectangleGeometry 强裁圆角） ===== -->
        <Border x:Name="BannerWrapper" Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="0" CornerRadius="12"
                MouseRightButtonDown="Banner_MouseRightButtonDown">
            <Grid x:Name="BannerGrid"
                  SizeChanged="BannerGrid_SizeChanged"
                  Loaded="BannerGrid_Loaded">
                <MediaElement x:Name="BannerVideo2" LoadedBehavior="Manual"
                              UnloadedBehavior="Stop" Opacity="0"
                              Stretch="UniformToFill" ScrubbingEnabled="True"
                              RenderOptions.BitmapScalingMode="HighQuality"/>
                <MediaElement x:Name="BannerVideo" LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Stretch="UniformToFill" ScrubbingEnabled="True"
                              RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="BannerPlaceholder" Text="&#xE714; 暂无轮播视频"
                           FontFamily="Microsoft YaHei UI" FontSize="16"
                           Foreground="{DynamicResource BorderBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button x:Name="PrevButton" Content="&#xE76B;"
                        FontFamily="Segoe MDL2 Assets" FontSize="20"
                        Width="36" Height="36" Opacity="0.6"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Click="PrevBanner_Click"
                        Style="{StaticResource WindowControlButtonStyle}"/>
                <Button x:Name="NextButton" Content="&#xE76C;"
                        FontFamily="Segoe MDL2 Assets" FontSize="20"
                        Width="36" Height="36" Opacity="0.6"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="NextBanner_Click"
                        Style="{StaticResource WindowControlButtonStyle}"/>
                <StackPanel x:Name="DotsPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,16"/>
            </Grid>
        </Border>

        <!-- ===== 目录入口（左侧）+ 公告（右侧）===== -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：目录卡片 + 一键开始 -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <!-- 三个目录卡片 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- 根目录 -->
                    <Border x:Name="RootDirCard" Grid.Column="0"
                            Style="{StaticResource CardStyle}" Cursor="Hand" Padding="16,14"
                            Margin="0,0,8,0"
                            MouseLeftButtonDown="Card_MouseDown"
                            MouseLeftButtonUp="Card_MouseUp"
                            MouseEnter="Card_MouseEnter"
                            MouseLeave="Card_MouseLeave"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                    Background="#1A1976D2" VerticalAlignment="Center">
                                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="根目录" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="访问工作根目录" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 图片目录 -->
                    <Border x:Name="ImageDirCard" Grid.Column="1"
                            Style="{StaticResource CardStyle}" Cursor="Hand" Padding="16,14"
                            Margin="4,0,4,0"
                            MouseLeftButtonDown="Card_MouseDown"
                            MouseLeftButtonUp="Card_MouseUp"
                            MouseEnter="Card_MouseEnter"
                            MouseLeave="Card_MouseLeave"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                    Background="#1A66BB6A" VerticalAlignment="Center">
                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="图片目录" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="浏览素材图片" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 视频目录 -->
                    <Border x:Name="VideoDirCard" Grid.Column="2"
                            Style="{StaticResource CardStyle}" Cursor="Hand" Padding="16,14"
                            Margin="8,0,0,0"
                            MouseLeftButtonDown="Card_MouseDown"
                            MouseLeftButtonUp="Card_MouseUp"
                            MouseEnter="Card_MouseEnter"
                            MouseLeave="Card_MouseLeave"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                    Background="#1AFF7043" VerticalAlignment="Center">
                                <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="视频目录" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="浏览视频素材" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 音频目录 -->
                    <Border x:Name="AudioDirCard" Grid.Column="3"
                            Style="{StaticResource CardStyle}" Cursor="Hand" Padding="16,14"
                            Margin="8,0,0,0"
                            MouseLeftButtonDown="Card_MouseDown"
                            MouseLeftButtonUp="Card_MouseUp"
                            MouseEnter="Card_MouseEnter"
                            MouseLeave="Card_MouseLeave"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                    Background="#1A9C27B0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="#E1BEE7"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="音频目录" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="浏览音频素材" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 一键开始 + GitHub -->
                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="准备开始创作" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="NovelCountText" Text="已导入 0 本小说"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                            <!-- GitHub 项目链接 -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="GitHubLink_Click"
                                        ToolTip="https://github.com/CookuBlack/Yangzai-Workshop">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="github.com/CookuBlack/Yangzai-Workshop"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextDecorations="Underline"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Click="StartButton_Click"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"
                                FontSize="15" FontFamily="Microsoft YaHei UI"
                                Cursor="Hand" Padding="28,14">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="8"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                  
                                                      <Setter TargetName="bd"
                                                                Property="Background"
                                                                Value="#FF8A65"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bd"
                                                                Property="Background"
                                                                Value="#E64A19"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="17" Foreground="White"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="  一键开始" FontSize="15"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 右侧公告栏 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="&#xE789;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Grid.Row="1" Text="公告" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,12"/>
                    <ScrollViewer Grid.Row="2" x:Name="NoticeScroller"
                                  VerticalScrollBarVisibility="Hidden"
                                  PreviewMouseWheel="NoticeScroller_PreviewMouseWheel">
                        <TextBlock x:Name="NoticeText" Text="加载中..."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
