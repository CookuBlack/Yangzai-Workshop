<UserControl x:Class="YangzaiWorkshop.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <ScrollViewer x:Name="SettingsScroller" VerticalScrollBarVisibility="Auto"
                  PreviewMouseWheel="SettingsScroller_PreviewMouseWheel">
        <StackPanel Margin="24">

            <!-- ===== 主题设置 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE790;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 主题设置"/>
                    </TextBlock>
                    <TextBlock Text="选择应用程序的外观风格" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="FollowSystemCheck" FontSize="13" Margin="0,0,0,10"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="FollowSystemCheck_Checked"
                              Unchecked="FollowSystemCheck_Unchecked">
                        <TextBlock>
                            <Run Text="跟随系统主题"/><LineBreak/>
                            <Run Text="自动根据 Windows 主题切换亮色/暗色模式" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <StackPanel x:Name="ThemeManualPanel" Orientation="Horizontal">
                        <RadioButton x:Name="LightRadio" GroupName="Theme" Margin="0,0,20,0"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="LightRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 亮色模式" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="DarkRadio" GroupName="Theme"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="DarkRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 暗色模式" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 工作目录 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 工作目录"/>
                    </TextBlock>
                    <TextBlock Text="所有小说、素材、配置的存储位置" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}"
                                CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                            <TextBlock x:Name="WorkPathText" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="12,6" Click="OpenWorkDir_Click">
                            <TextBlock>
                                <Run Text="&#xE838;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 打开"/>
                            </TextBlock>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 通用设置 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE713;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 通用设置"/>
                    </TextBlock>
                    <TextBlock Text="编辑器与播放器行为偏好" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="AutoSaveCheck" Margin="0,0,0,10"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="AutoSaveCheck_Changed" Unchecked="AutoSaveCheck_Changed">
                        <TextBlock>
                            <Run Text="剧本编辑失焦自动保存"/><LineBreak/>
                            <Run Text="编辑器失去焦点时自动保存当前内容" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认字体大小" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Width="80"/>
                            <Slider x:Name="FontSizeSlider" Grid.Column="1"
                                    Minimum="10" Maximum="24" Margin="8,0"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="4" Padding="8,2" MinWidth="40">
                                <TextBlock x:Name="FontSizeLabel" Text="14px" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <CheckBox x:Name="AutoPlayCheck" Margin="0,0,0,10"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="AutoPlayCheck_Changed" Unchecked="AutoPlayCheck_Changed">
                        <TextBlock>
                            <Run Text="首页轮播自动播放"/><LineBreak/>
                            <Run Text="打开应用时自动开始播放轮播视频" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轮播间隔" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Width="80"/>
                            <Slider x:Name="IntervalSlider" Grid.Column="1"
                                    Minimum="2" Maximum="15" Margin="8,0"
                                    ValueChanged="IntervalSlider_ValueChanged"/>
                            <Border Grid.Column="2" Background="{DynamicResource AccentBrush}"
                                    CornerRadius="4" Padding="8,2" MinWidth="40">
                                <TextBlock x:Name="IntervalLabel" Text="5秒" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 公告编辑 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                                <Run Text="&#xE789;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 公告内容"/>
                            </TextBlock>
                            <TextBlock Text="首页右侧显示的公告，支持多行文本" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12" Padding="12,6" HorizontalAlignment="Right"
                                Click="SaveNotice_Click">
                            <TextBlock>
                                <Run Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 保存公告"/>
                            </TextBlock>
                        </Button>
                    </Grid>
                    <TextBox x:Name="NoticeEditBox" Grid.Row="1" MinHeight="120"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ModernTextBoxStyle}" FontSize="13"/>
                    <TextBlock x:Name="NoticeSaveStatus" Grid.Row="2"
                               FontSize="11" Margin="0,6,0,0"
                               Foreground="{DynamicResource SuccessBrush}"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- ===== 数据备份与恢复 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 数据备份与恢复"/>
                    </TextBlock>
                    <TextBlock Text="保护你的创作数据不丢失" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="13" Padding="16,8" Margin="0,0,12,0"
                                Click="BackupData_Click">
                            <TextBlock>
                                <Run Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 一键备份"/>
                            </TextBlock>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="13" Padding="16,8"
                                Click="RestoreData_Click">
                            <TextBlock>
                                <Run Text="&#xE777;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 恢复数据"/>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 关于 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 关于"/>
                    </TextBlock>
                    <TextBlock Text="Yangzai Workshop 相关信息" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                ClipToBounds="True">
                            <Image x:Name="AboutIcon" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Yangzai Workshop" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="VersionSubText" Text="版本 v1.0.0" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Separator Opacity="0.3" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="版本号" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="VersionLabel" Text="v1.0.0" FontSize="12"
                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="更新日期" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="UpdateDateLabel" Text="2025-01-01"
                                   FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="开源协议" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="MIT License" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <TextBlock x:Name="GitHubLink" FontSize="12" Margin="0,6,0,0"
                               Foreground="{DynamicResource PrimaryBrush}"
                               TextDecorations="Underline" Cursor="Hand"
                               MouseLeftButtonDown="GitHubLink_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
