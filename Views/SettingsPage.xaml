<UserControl x:Class="YangzaiWorkshop.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <ScrollViewer x:Name="SettingsScroller" VerticalScrollBarVisibility="Auto"
                  PreviewMouseWheel="SettingsScroller_PreviewMouseWheel">
        <StackPanel Margin="24">

            <!-- ===== 主题设置 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE790;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 主题设置"/>
                    </TextBlock>
                    <TextBlock Text="选择应用程序的外观风格" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="FollowSystemCheck" FontSize="13" Margin="0,0,0,10"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="FollowSystemCheck_Checked"
                              Unchecked="FollowSystemCheck_Unchecked">
                        <TextBlock>
                            <Run Text="跟随系统主题"/><LineBreak/>
                            <Run Text="自动根据 Windows 主题切换亮色/暗色模式" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <StackPanel x:Name="ThemeManualPanel" Orientation="Horizontal">
                        <RadioButton x:Name="LightRadio" GroupName="Theme" Margin="0,0,8,0"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="LightRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 亮色模式" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="DarkRadio" GroupName="Theme" Margin="0,0,8,0"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="DarkRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 暗色模式" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="GlassRadio" GroupName="Theme" Margin="0,0,8,0"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="GlassRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE7C6;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 天空之蓝" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="CustomRadio" GroupName="Theme"
                                     FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="CustomRadio_Checked">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="8" Padding="14,10" Cursor="Hand"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="20" Height="20" CornerRadius="10"
                                                    Background="{DynamicResource HoverBrush}"
                                                    BorderBrush="Transparent" BorderThickness="2">
                                                <Ellipse x:Name="dot" Fill="{DynamicResource PrimaryBrush}"
                                                         Width="10" Height="10" Visibility="Collapsed"/>
                                            </Border>
                                            <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 自定义" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource PrimaryLowBrush}"/>
                                            <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>

                    <!-- ===== 自定义主题配置面板 ===== -->
                    <Border x:Name="CustomThemePanel" Visibility="Collapsed"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="自定义主题 — 选择一个背景色或上传背景图"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="点击色块选背景色，色/图为同一优先级（选色清图）"
                                       FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,12"/>

                            <!-- 预设颜色调色板 -->
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="8" Padding="8" Margin="0,0,0,12">
                                <WrapPanel x:Name="ColorPalettePanel"/>
                            </Border>

                            <!-- 背景图片 -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="背景图片" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="上传一张图片作为窗口背景（可调节透明度和模糊度）"
                                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：预览缩略图 + 操作按钮 -->
                                        <Grid Grid.Column="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 预览缩略图 -->
                                            <Border Grid.Column="0" Width="72" Height="48" CornerRadius="6"
                                                    Background="{DynamicResource WindowBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    ClipToBounds="True" Margin="0,0,10,0">
                                                <Image x:Name="BgPreviewImage" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button x:Name="SelectBgImageBtn"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="SelectBgImage_Click">
                                                        <TextBlock>
                                                            <Run Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"/>
                                                            <Run Text=" 选择图片"/>
                                                        </TextBlock>
                                                    </Button>
                                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                                            FontSize="11" Padding="10,4" Margin="6,0,0,0"
                                                            Click="ClearBgImage_Click">
                                                        <TextBlock>
                                                            <Run Text="&#xE894;" FontFamily="Segoe MDL2 Assets"/>
                                                            <Run Text=" 清除"/>
                                                        </TextBlock>
                                                    </Button>
                                                </StackPanel>
                                                <TextBlock x:Name="BgImagePathText" FontSize="10"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis" Text="未选择图片"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 右侧：前景 UI 风格（右对齐） -->
                                        <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}"
                                                CornerRadius="8" Padding="12,8"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                VerticalAlignment="Top" Margin="16,0,0,0">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="前景风格" FontSize="11" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton x:Name="ImgFgLightRadio" GroupName="ImgForeground"
                                                                 FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 Margin="0,0,14,0" Checked="ImgForeground_Changed">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="18" Height="18" CornerRadius="4"
                                                                    Background="#F5F0E6" Margin="0,0,5,0"
                                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                                            <TextBlock Text="奶白色" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </RadioButton>
                                                    <RadioButton x:Name="ImgFgDarkRadio" GroupName="ImgForeground"
                                                                 FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 Checked="ImgForeground_Changed">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="18" Height="18" CornerRadius="4"
                                                                    Background="#2D2D2D" Margin="0,0,5,0"
                                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                                            <TextBlock Text="暗色" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </RadioButton>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- 透明度 -->
                                    <TextBlock Text="💡 透明度越高图像越清晰，模糊度越低图像越清晰"
                                               FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"
                                               Margin="0,12,0,6"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="透明度" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Slider x:Name="BgOpacitySlider" Grid.Column="1"
                                                Minimum="0.05" Maximum="1" SmallChange="0.05"
                                                ValueChanged="BgOpacity_Changed" Margin="4,0"/>
                                        <Border Grid.Column="2" Background="{DynamicResource HoverBrush}"
                                                CornerRadius="4" Padding="6,2" MinWidth="40">
                                            <TextBlock x:Name="BgOpacityLabel" Text="35%" FontSize="11"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- 模糊度 -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="模糊度" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Slider x:Name="BgBlurSlider" Grid.Column="1"
                                                Minimum="0" Maximum="50" SmallChange="1"
                                                ValueChanged="BgBlur_Changed" Margin="4,0"/>
                                        <Border Grid.Column="2" Background="{DynamicResource HoverBrush}"
                                                CornerRadius="4" Padding="6,2" MinWidth="40">
                                            <TextBlock x:Name="BgBlurLabel" Text="15px" FontSize="11"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 提示文字 -->
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,12,0,6" TextWrapping="Wrap"
                                       Text="调整透明度和模糊度后，点击下方按钮应用效果。更改将在重启后完全生效。"/>

                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="12" Padding="14,6" Margin="0,0,8,0"
                                        Click="ResetCustomTheme_Click">
                                    <TextBlock>
                                        <Run Text="&#xE777;" FontFamily="Segoe MDL2 Assets"/>
                                        <Run Text=" 恢复默认"/>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        FontSize="12" Padding="16,6"
                                        Click="ApplyBgEffect_Click">
                                    <TextBlock>
                                        <Run Text="&#xE930;" FontFamily="Segoe MDL2 Assets"/>
                                        <Run Text=" 应用效果并重启"/>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 工作目录 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 工作目录"/>
                    </TextBlock>
                    <TextBlock Text="所有小说、素材、配置的存储位置" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}"
                                CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                            <TextBlock x:Name="WorkPathText" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="12,6" Click="OpenWorkDir_Click">
                            <TextBlock>
                                <Run Text="&#xE838;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 打开"/>
                            </TextBlock>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 通用设置 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE713;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 通用设置"/>
                    </TextBlock>
                    <TextBlock Text="编辑器与播放器行为偏好" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="AutoSaveCheck" Margin="0,0,0,10"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="AutoSaveCheck_Changed" Unchecked="AutoSaveCheck_Changed">
                        <TextBlock>
                            <Run Text="剧本编辑失焦自动保存"/><LineBreak/>
                            <Run Text="编辑器失去焦点时自动保存当前内容" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认字体大小" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Width="80"/>
                            <Slider x:Name="FontSizeSlider" Grid.Column="1"
                                    Minimum="10" Maximum="24" Margin="8,0"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="4" Padding="8,2" MinWidth="40">
                                <TextBlock x:Name="FontSizeLabel" Text="14px" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <CheckBox x:Name="AutoPlayCheck" Margin="0,0,0,10"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="AutoPlayCheck_Changed" Unchecked="AutoPlayCheck_Changed">
                        <TextBlock>
                            <Run Text="首页轮播自动播放"/><LineBreak/>
                            <Run Text="打开应用时自动开始播放轮播视频" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轮播间隔" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Width="80"/>
                            <Slider x:Name="IntervalSlider" Grid.Column="1"
                                    Minimum="2" Maximum="15" Margin="8,0"
                                    ValueChanged="IntervalSlider_ValueChanged"/>
                            <Border Grid.Column="2" Background="{DynamicResource AccentBrush}"
                                    CornerRadius="4" Padding="8,2" MinWidth="40">
                                <TextBlock x:Name="IntervalLabel" Text="5秒" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 音乐播放器 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xEC4F;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 音乐播放器"/>
                    </TextBlock>
                    <TextBlock Text="添加背景音乐，创作时随时播放"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- 启动时自动播放 -->
                    <CheckBox x:Name="MusicAutoPlayCheck" Content="启动时自动播放音乐"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Margin="0,0,0,10"
                              Checked="MusicAutoPlayCheck_Changed"
                              Unchecked="MusicAutoPlayCheck_Changed"/>

                    <!-- 管理音乐按钮 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ 上传音乐" FontSize="12"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="12,4" Margin="0,0,12,0"
                                Click="SettingsMusicAdd_Click"/>
                        <Button Content="打开音乐文件夹" FontSize="12"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,4"
                                Click="SettingsOpenMusicDir_Click"/>
                    </StackPanel>

                    <!-- 音乐列表 -->
                    <TextBlock x:Name="SettingsMusicCount" Text="暂无音乐文件"
                               FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,10,0,6"/>
                    <ItemsControl x:Name="SettingsMusicList" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="8,6" CornerRadius="6"
                                        Background="{DynamicResource WindowBackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                Width="24" Height="24" Padding="0"
                                                Background="Transparent"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="SettingsMusicDelete_Click" ToolTip="删除"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 自动更新 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE895;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 自动更新"/>
                    </TextBlock>
                    <TextBlock Text="从 GitHub 自动检测并下载最新版本" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="CheckUpdateBtn" Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12" Padding="16,8" Click="CheckUpdate_Click">
                            <TextBlock>
                                <Run Text="&#xE895;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 检查更新"/>
                            </TextBlock>
                        </Button>
                        <TextBlock x:Name="UpdateStatusLabel" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>


            <!-- ===== 数据备份与恢复 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 数据备份与恢复"/>
                    </TextBlock>
                    <TextBlock Text="保护你的创作数据不丢失" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="13" Padding="16,8" Margin="0,0,12,0"
                                Click="BackupData_Click">
                            <TextBlock>
                                <Run Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 一键备份"/>
                            </TextBlock>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="13" Padding="16,8"
                                Click="RestoreData_Click">
                            <TextBlock>
                                <Run Text="&#xE777;" FontFamily="Segoe MDL2 Assets"/>
                                <Run Text=" 恢复数据"/>
                            </TextBlock>
                        </Button>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0" Margin="0,12,0,10"/>
                    <CheckBox x:Name="AutoBackupCheck" Margin="0,0,0,10"
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="AutoBackupCheck_Changed" Unchecked="AutoBackupCheck_Changed">
                        <TextBlock>
                            <Run Text="启用自动备份"/><LineBreak/>
                            <Run Text="按设定间隔自动生成 ZIP 备份文件" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </CheckBox>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="备份间隔" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Width="80"/>
                            <Slider x:Name="BackupIntervalSlider" Grid.Column="1"
                                    Minimum="1" Maximum="72" Margin="8,0"
                                    ValueChanged="BackupIntervalSlider_ValueChanged"/>
                            <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="4" Padding="8,2" MinWidth="40">
                                <TextBlock x:Name="BackupIntervalLabel" Text="24小时" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== AI 模型配置 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="🤖" /><Run Text=" AI 模型配置"/>
                    </TextBlock>
                    <TextBlock Text="配置大模型 API，用于生成剧本内容和创作提示词" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="API 地址" FontSize="12" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox x:Name="ApiEndpointBox" Margin="0,0,0,10"
                             Style="{StaticResource ModernTextBoxStyle}" FontSize="12"
                             LostFocus="ApiEndpointBox_LostFocus"/>

                    <TextBlock Text="API 密钥" FontSize="12" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,10"
                                 Style="{StaticResource ModernPasswordBoxStyle}" FontSize="12"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>

                    <TextBlock Text="文本模型" FontSize="12" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ApiModelBox" Grid.Column="0" IsEditable="True"
                                  Style="{StaticResource ModernComboBoxStyle}" MinHeight="28"
                                  SelectionChanged="ApiModelBox_SelectionChanged"
                                  LostFocus="ApiModelBox_LostFocus"
                                  PreviewMouseWheel="ComboBox_PreviewMouseWheel" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="⬇ 获取模型列表"
                                FontSize="11" Padding="8,5"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="FetchModels_Click"/>
                    </Grid>

                    <TextBlock Text="图片模型" FontSize="12" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="ImageModelBox" IsEditable="True" Margin="0,0,0,10"
                              Style="{StaticResource ModernComboBoxStyle}" MinHeight="28"
                              LostFocus="ImageModelBox_LostFocus"
                              PreviewMouseWheel="ComboBox_PreviewMouseWheel"/>

                    <TextBlock Text="视频模型" FontSize="12" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="VideoModelBox" IsEditable="True" Margin="0,0,0,10"
                              Style="{StaticResource ModernComboBoxStyle}" MinHeight="28"
                              LostFocus="VideoModelBox_LostFocus"
                              PreviewMouseWheel="ComboBox_PreviewMouseWheel"/>
                </StackPanel>
            </Border>

            <!-- ===== AI 生成 Skill ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,0,0,12">
                <Grid>
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2">
                            <Run Text="🎬" /><Run Text=" AI 生成 Skill"/>
                        </TextBlock>
                        <TextBlock Text="自定义剧本生成和提示词生成的 AI 指令" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="12" Padding="14,6"
                            Click="EditSkill_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,6,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="编辑 Skill"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== 恢复默认 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,0,0,12">
                <Grid>
                    <TextBlock Text="重置所有设置为出厂默认值" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="12" Padding="16,8"
                            Click="ResetGeneralSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Margin="0,0,6,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="恢复默认设置"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== 关于 ===== -->
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4">
                        <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets"/>
                        <Run Text=" 关于"/>
                    </TextBlock>
                    <TextBlock Text="Yangzai Workshop 相关信息" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                ClipToBounds="True">
                            <Image x:Name="AboutIcon" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Yangzai Workshop" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="VersionSubText" Text="版本 v2.0.0" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Separator Opacity="0.3" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="版本号" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="VersionLabel" Text="v2.0.0" FontSize="12"
                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="更新日期" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="UpdateDateLabel" Text="2025-01-01"
                                   FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="开源协议" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="MIT License" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <TextBlock x:Name="GitHubLink" FontSize="12" Margin="0,6,0,0"
                               Foreground="{DynamicResource PrimaryBrush}"
                               TextDecorations="Underline" Cursor="Hand"
                               MouseLeftButtonDown="GitHubLink_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
