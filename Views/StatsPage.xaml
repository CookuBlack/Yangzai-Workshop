<UserControl x:Class="YangzaiWorkshop.Views.StatsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightPanelCol" Width="240" MinWidth="0"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：图表 -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 平台切换 + 面板按钮（同一行延长） -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="6" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- 平台按钮：绝对居中 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="DouyinBtn" Content="抖音" FontSize="13" FontFamily="Microsoft YaHei UI"
                                Padding="16,6" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="DouyinBtn_Click"/>
                        <Button x:Name="KuaishouBtn" Content="快手" FontSize="13" FontFamily="Microsoft YaHei UI"
                                Padding="16,6" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="KuaishouBtn_Click"/>
                        <Button x:Name="BilibiliBtn" Content="Bilibili" FontSize="13" FontFamily="Microsoft YaHei UI"
                                Padding="16,6"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BilibiliBtn_Click"/>
                    </StackPanel>
                    <!-- 导出/导入 + 展开/收起按钮（右对齐） -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="导出" FontSize="11" FontFamily="Microsoft YaHei UI"
                                Padding="8,3" Margin="0,0,4,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ExportData_Click" ToolTip="导出数据"/>
                        <Button Content="导入" FontSize="11" FontFamily="Microsoft YaHei UI"
                                Padding="8,3" Margin="0,0,4,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ImportData_Click" ToolTip="导入数据"/>
                        <Button Content=">"
                                FontSize="13" FontWeight="Bold" FontFamily="Microsoft YaHei UI"
                                Width="28" Height="28" Padding="0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="TogglePanel_Click" ToolTip="收起面板"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 三图表 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="4" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="播放量趋势"
                                   FontSize="13" FontWeight="Bold" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="播放量"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,2,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><RotateTransform Angle="-90"/></TextBlock.RenderTransform>
                        </TextBlock>
                        <ScottPlot:WpfPlot Grid.Row="1" Grid.Column="1" x:Name="PlayChart" Margin="0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="日期"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="4" Margin="0,4,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="点赞量趋势"
                                   FontSize="13" FontWeight="Bold" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="点赞量"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,2,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><RotateTransform Angle="-90"/></TextBlock.RenderTransform>
                        </TextBlock>
                        <ScottPlot:WpfPlot Grid.Row="1" Grid.Column="1" x:Name="LikeChart" Margin="0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="日期"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="4" Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="评论量趋势"
                                   FontSize="13" FontWeight="Bold" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="评论量"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,2,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><RotateTransform Angle="-90"/></TextBlock.RenderTransform>
                        </TextBlock>
                        <ScottPlot:WpfPlot Grid.Row="1" Grid.Column="1" x:Name="CommentChart" Margin="0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="日期"
                                   FontSize="10" FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 右侧面板 -->
        <Border x:Name="RightPanel" Grid.Column="1" Style="{StaticResource CardStyle}"
                Padding="12" Margin="8,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="数据录入" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 录入表单（标签固定宽度对齐） -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="日期" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,4"/>
                        <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,4">
                            <ToggleButton x:Name="DateBtn" Cursor="Hand"
                                          IsChecked="{Binding IsOpen, ElementName=DatePopup, Mode=TwoWay}"
                                          Style="{StaticResource DatePickerToggleStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="DateBtnText" Text="2026/6/20"
                                               FontSize="12" FontFamily="Microsoft YaHei UI"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup x:Name="DatePopup" StaysOpen="False"
                                   AllowsTransparency="True" Opened="DatePopup_Opened"
                                   PlacementTarget="{Binding ElementName=DateBtn}"
                                   Placement="Bottom">
                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="8"
                                        MinWidth="210">
                                    <StackPanel>
                                        <!-- 月/年标题 + 翻页按钮 -->
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="&lt;" FontSize="13"
                                                    FontWeight="Bold"
                                                    Style="{StaticResource DateCalNavButton}"
                                                    Click="CalPrevMonth_Click"/>
                                            <TextBlock x:Name="CalMonthLabel" Grid.Column="1"
                                                       Text="2026年6月" FontSize="13" FontWeight="Bold"
                                                       FontFamily="Microsoft YaHei UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="&gt;" FontSize="13"
                                                    FontWeight="Bold"
                                                    Style="{StaticResource DateCalNavButton}"
                                                    Click="CalNextMonth_Click"/>
                                        </Grid>
                                        <!-- 星期头 -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="日" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="一" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="二" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="三" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="四" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="五" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="六" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Grid>
                                        <!-- 日期网格（42个格子：6行×7列） -->
                                        <Grid x:Name="CalDayGrid"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="播放量" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,4"/>
                        <TextBox x:Name="PlaysInput" Grid.Row="1" Grid.Column="1" FontSize="12"
                                 FontFamily="Microsoft YaHei UI" Padding="6,3" Margin="0,0,0,4"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="点赞量" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,4"/>
                        <TextBox x:Name="LikesInput" Grid.Row="2" Grid.Column="1" FontSize="12"
                                 FontFamily="Microsoft YaHei UI" Padding="6,3" Margin="0,0,0,4"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="评论量" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,4"/>
                        <TextBox x:Name="CommentsInput" Grid.Row="3" Grid.Column="1" FontSize="12"
                                 FontFamily="Microsoft YaHei UI" Padding="6,3" Margin="0,0,0,4"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>

                        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                Content="添加数据" FontSize="12"
                                Padding="12,6"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddData_Click"/>
                    </Grid>

                    <!-- 已录入数据（可拖拽排序） -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="已录入数据（长按拖拽排序）" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl x:Name="DataList"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
