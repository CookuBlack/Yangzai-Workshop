<Window x:Class="YangzaiWorkshop.Views.RelationshipMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="人物关系图" Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#40000000" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <TextBlock Text="🔗 人物关系图" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <TextBlock x:Name="MapTitle" FontSize="11"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center" Margin="140,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="➕ 新建" FontSize="11" Width="Auto" Height="26"
                                Padding="10,0,10,0" MinWidth="62" Margin="0,0,6,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CreateCharacter_Click" ToolTip="新建角色"/>
                        <Button x:Name="ConnectModeBtn" Content="🔗 连线模式"
                                FontSize="11" Width="Auto" Height="26" Padding="10,0,10,0"
                                MinWidth="80" Margin="0,0,6,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ConnectModeBtn_Click"/>
                        <Button Content="🖼 背景" FontSize="11" Width="Auto" Height="26"
                                Padding="10,0,10,0" MinWidth="56"
                                Margin="0,0,6,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ChangeBackground_Click"/>
                        <Button Content="✕" FontSize="13" Width="30" Height="30"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 画布 -->
            <Border Grid.Row="1" ClipToBounds="True" Margin="4,0,4,4" CornerRadius="6">
                <Grid>
                    <Image x:Name="BgImage" Stretch="UniformToFill" Opacity="0.12" IsHitTestVisible="False"/>
                    <Canvas x:Name="MainCanvas" Background="Transparent"
                            MouseLeftButtonDown="Canvas_MouseDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseUp"
                            MouseWheel="Canvas_MouseWheel"
                            MouseRightButtonDown="Canvas_RightClick">
                        <Canvas x:Name="LinesLayer" Panel.ZIndex="0" IsHitTestVisible="False"/>
                        <Canvas x:Name="NodesLayer" Panel.ZIndex="1"/>
                        <Line x:Name="DragLine" Panel.ZIndex="2"
                              Stroke="{DynamicResource PrimaryBrush}"
                              StrokeThickness="2.5" StrokeDashArray="6,3"
                              Visibility="Collapsed" IsHitTestVisible="False"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- 底部栏 -->
            <Border Grid.Row="2" Padding="10,6" Margin="4,0,4,4"
                    CornerRadius="0,0,6,6"
                    Background="{DynamicResource SidebarBackgroundBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ModeHint" FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
