<UserControl x:Class="YangzaiWorkshop.Views.ScriptPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="NovelListCol" Width="160" MinWidth="150"/>
        </Grid.ColumnDefinitions>

        <!-- 主区域 -->
        <Grid Grid.Column="0" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部章节导航栏（鼠标滚轮横向滚动 + 展开弹窗） -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="ChapterTabsScroller" Grid.Column="0"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ChapterTabsScroller_PreviewMouseWheel">
                        <StackPanel x:Name="ChapterTabsPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                    <!-- 展开按钮 -->
                    <Button x:Name="ChapterExpandBtn" Grid.Column="1"
                            Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                            FontSize="13" MinWidth="28" MinHeight="28"
                            Margin="4,0,0,0" Padding="0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ChapterExpandBtn_Click" ToolTip="展开章节列表"/>
                </Grid>
            </Border>

            <!-- 章节展开弹窗（多列网格，边界到书籍列表左边缘） -->
            <Popup x:Name="ChapterPopup" PlacementTarget="{Binding ElementName=ChapterExpandBtn}"
                   Placement="Bottom" StaysOpen="False"
                   AllowsTransparency="True" PopupAnimation="Slide">
                <Border x:Name="ChapterPopupBorder" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        MaxHeight="400" MinWidth="400">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid x:Name="ChapterPopupList" Columns="4" Margin="4"/>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- 三栏可折叠可拖拽调整宽度内容区域 -->
            <Grid Grid.Row="1" ClipToBounds="True" x:Name="ContentGrid"
                  SizeChanged="ContentGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="OriginalCol" Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="ScriptCol" Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="ImageCol" Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ===== 小说原内容 ===== -->
                <Border x:Name="OriginalPanel" Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}"
                        Margin="0,0,0,0">
                    <Grid>
                        <!-- 展开状态：正常内容 -->
                        <Grid x:Name="OriginalContentGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 标题栏 -->
                            <Border Grid.Row="0" Padding="10,6"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="小说内容" FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Padding="4,2" Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="CopyOriginal_Click" ToolTip="复制"/>
                                        <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Padding="4,2" Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ToggleOriginal_Click" ToolTip="收起/展开"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <RichTextBox x:Name="OriginalTextBox" Grid.Row="1"
                                         BorderThickness="0"
                                         Background="Transparent" Padding="10"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="14" FontFamily="Microsoft YaHei UI"
                                         AllowDrop="False"
                                         LostFocus="OriginalTextBox_LostFocus">
                                <RichTextBox.Resources>
                                    <Style TargetType="Paragraph">
                                        <Setter Property="LineHeight" Value="26"/>
                                    </Style>
                                </RichTextBox.Resources>
                                <RichTextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="标红" Click="HighlightRed_Click" Tag="#E81123"/>
                                        <MenuItem Header="标蓝" Click="HighlightColor_Click" Tag="#1976D2"/>
                                        <MenuItem Header="标绿" Click="HighlightColor_Click" Tag="#66BB6A"/>
                                        <MenuItem Header="标橙" Click="HighlightColor_Click" Tag="#FF7043"/>
                                        <MenuItem Header="标黄" Click="HighlightColor_Click" Tag="#FFD600"/>
                                        <Separator/>
                                        <MenuItem Header="清除标记" Click="ClearHighlight_Click"/>
                                    </ContextMenu>
                                </RichTextBox.ContextMenu>
                            </RichTextBox>
                        </Grid>

                        <!-- 收起状态：干净竖条（图标 + 箭头） -->
                        <Grid x:Name="OriginalCollapsedView" Visibility="Collapsed">
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <!-- 图标 -->
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           ToolTip="小说内容"/>
                                <!-- 展开箭头 -->
                                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="12" Width="24" Height="24" Padding="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ToggleOriginal_Click" ToolTip="展开小说内容"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- GridSplitter 1 -->
                <GridSplitter x:Name="Splitter1" Grid.Column="1" Width="4"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent"
                              DragDelta="Splitter1_DragDelta"
                              DragCompleted="Splitter_DragCompleted"
                              PreviewMouseDoubleClick="Splitter_DoubleClick"/>

                <!-- ===== 剧本内容 ===== -->
                <Border x:Name="ScriptPanel" Grid.Column="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}">
                    <Border.LayoutTransform>
                        <ScaleTransform x:Name="ScriptPanelScale" ScaleX="1" ScaleY="1"/>
                    </Border.LayoutTransform>
                    <Grid>
                        <!-- 展开状态：正常内容 -->
                        <Grid x:Name="ScriptContentGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="10,6"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock x:Name="ScriptModeIcon" Text="&#xE70B;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource SuccessBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="ScriptModeLabel" Text="剧本内容" FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="AiScriptBtn" Content="🤖 AI 生成"
                                                FontSize="11" Padding="6,3" Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="AiGenerateScript_Click" ToolTip="AI 生成剧本内容"/>
                                        <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Padding="4,2" Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="CopyScript_Click" ToolTip="复制"/>
                                        <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Padding="4,2" Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ToggleScript_Click" ToolTip="收起/展开"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <!-- 剧本内容纯文本编辑 -->
                            <TextBox x:Name="ScriptEditBox" Grid.Row="1"
                                     BorderThickness="0"
                                     TextBlock.LineHeight="26"
                                     PreviewMouseDoubleClick="ScriptEditBox_PreviewMouseDoubleClick"
                                     Background="Transparent" Padding="10"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="14" FontFamily="Microsoft YaHei UI" />
                        </Grid>

                        <!-- 收起状态：干净竖条 -->
                        <Grid x:Name="ScriptCollapsedView" Visibility="Collapsed">
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           ToolTip="剧本内容"/>
                                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="12" Width="24" Height="24" Padding="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ToggleScript_Click" ToolTip="展开剧本内容"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- GridSplitter 2 -->
                <GridSplitter x:Name="Splitter2" Grid.Column="3" Width="4"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent"
                              DragDelta="Splitter2_DragDelta"
                              DragCompleted="Splitter_DragCompleted"
                              PreviewMouseDoubleClick="Splitter_DoubleClick"/>

                <!-- ===== 图像素材 ===== -->
                <Border x:Name="ImagePanel" Grid.Column="4"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}"
                        ClipToBounds="True">
                    <Grid>
                        <!-- 展开状态：正常内容 -->
                        <Grid x:Name="ImageContentGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="10,6"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="图像素材" FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="MultiSelectToggleBtn" Content="☐ 多选"
                                                FontSize="11" Padding="6,3" Margin="0,0,4,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ToggleMultiSelect_Click" ToolTip="开启多选模式"/>
                                        <Button x:Name="CopySelectedBtn" Content="📋 复制选中"
                                                FontSize="11" Padding="6,3" Margin="0,0,4,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="CopySelected_Click" ToolTip="复制选中的素材"
                                                Visibility="Collapsed"/>
                                        <Button x:Name="AiImageBtn" Content="🤖 AI 生图"
                                                FontSize="11" Padding="6,3" Margin="0,0,4,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="AiGenerateImage_Click" ToolTip="AI 生成图片"/>
                                        <Button Content="+ 添加" FontFamily="Microsoft YaHei UI"
                                                FontSize="11" Padding="6,3" Margin="0,0,6,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="AddImage_Click" ToolTip="添加图像素材"/>
                                        <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Padding="4,2"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ToggleImage_Click" ToolTip="收起/展开"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          AllowDrop="True"
                                          Drop="ImageGrid_Drop" DragOver="ImageGrid_DragOver">
                                <Grid x:Name="ImageGrid" AllowDrop="True"
                                      Drop="ImageGrid_Drop" DragOver="ImageGrid_DragOver">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <!-- 收起状态：干净竖条 -->
                        <Grid x:Name="ImageCollapsedView" Visibility="Collapsed">
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"
                                           ToolTip="图像素材"/>
                                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="12" Width="24" Height="24" Padding="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ToggleImage_Click" ToolTip="展开图像素材"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- GridSplitter 3：图像面板右边界拖拽 -->
                <GridSplitter x:Name="Splitter3" Grid.Column="5" Width="4"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent"
                              DragDelta="Splitter3_DragDelta"
                              DragCompleted="Splitter3_DragCompleted"
                              PreviewMouseDoubleClick="Splitter_DoubleClick"/>
            </Grid>
        </Grid>

        <!-- 右侧书籍导航栏 -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,16,16,16" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,0,8">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="书籍列表" FontSize="12" FontWeight="Bold"
                               FontFamily="Microsoft YaHei UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <WrapPanel x:Name="NovelListPanel"/>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button Content="+ 导入小说" Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="12" Padding="8,6" Margin="0,0,0,4"
                            Click="ImportNovel_Click"/>
                    <Button Content="+ 新建小说" Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="12" Padding="8,6"
                            Click="CreateNovel_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 复制成功浮动提示（跨列居中） -->
        <Border x:Name="CopyToast" Grid.ColumnSpan="2"
                Background="#E0333333" CornerRadius="8" Padding="16,10"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Opacity="0" Margin="0,0,0,24" IsHitTestVisible="False">
            <TextBlock x:Name="CopyToastText" Text="✓ 复制成功"
                       Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
