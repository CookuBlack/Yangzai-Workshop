<UserControl x:Class="YangzaiWorkshop.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  PreviewMouseWheel="ProfileScroller_MouseWheel">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 个人信息区 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 头像（点击裁剪） -->
                    <Grid Grid.Column="0" Margin="0,0,20,0" Cursor="Hand"
                          MouseLeftButtonDown="Avatar_Click">
                        <Ellipse Width="90" Height="90" Fill="{DynamicResource PrimaryBrush}"/>
                        <Ellipse Width="90" Height="90">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="AvatarPlaceholder" Text="+" FontSize="48" FontWeight="Light"
                                   FontFamily="Microsoft YaHei UI" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 名称+简介（无框纯文字） -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- 查看模式 -->
                        <StackPanel x:Name="ViewPanel">
                            <TextBlock x:Name="UserNameDisplay" Text="创作者" FontSize="20" FontWeight="Bold"
                                       FontFamily="Microsoft YaHei UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="SignatureDisplay" Text="用漫剧讲述精彩故事" FontSize="13"
                                       FontFamily="Microsoft YaHei UI"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- 编辑模式 -->
                        <StackPanel x:Name="EditPanel" Visibility="Collapsed">
                            <TextBox x:Name="UserNameEdit" FontSize="20" FontWeight="Bold"
                                     FontFamily="Microsoft YaHei UI"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="Transparent" BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,1" Padding="0,0,0,4"/>
                            <TextBox x:Name="SignatureEdit" FontSize="13" FontFamily="Microsoft YaHei UI"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     Background="Transparent" BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,1" Padding="0,0,0,4"
                                     Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 编辑/保存按钮（笔图标） -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Orientation="Horizontal">
                        <Button x:Name="EditButton" FontSize="12"
                                Width="32" Height="32" Padding="0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="EditButton_Click" ToolTip="编辑">
                            <TextBlock Text="✎" FontSize="16" FontFamily="Microsoft YaHei UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 个人成就 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="个人成就" FontSize="16" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Button Content="+ 新建作品" Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12" Padding="10,4" HorizontalAlignment="Right"
                                Click="AddNovel_Click"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="AchievementPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
