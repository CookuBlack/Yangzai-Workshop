<UserControl x:Class="YangzaiWorkshop.Views.ToolboxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24">
        <StackPanel>
            <TextBlock Text="工具箱" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- 小说素材下载 -->
            <Border Style="{StaticResource CardStyle}" Padding="20"
                    Cursor="Hand" Margin="0,0,0,12"
                    MouseLeftButtonDown="NovelCard_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="{DynamicResource PrimaryBrush}" Margin="0,0,16,0">
                        <TextBlock Text="N" FontSize="22" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="小说素材下载" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="前往 isyd.net 搜索和下载小说原文素材"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text=">"
                               FontFamily="Microsoft YaHei" FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 打开工作目录 -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12"
                    Cursor="Hand"
                    MouseLeftButtonDown="OpenRootDir_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="{DynamicResource SuccessBrush}" Margin="0,0,16,0">
                        <TextBlock Text="F" FontSize="22" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="打开工作目录" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="通过资源管理器查看所有工作文件"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text=">"
                               FontFamily="Microsoft YaHei" FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 回收站（点击弹出） -->
            <Border Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,0,0,12"
                    Cursor="Hand"
                    MouseLeftButtonDown="TrashCard_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="#FF666666" Margin="0,0,14,0">
                        <TextBlock Text="T" FontSize="22" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="回收站" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="已删除文件 · 保留30天"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text=">" FontFamily="Microsoft YaHei" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- 备忘录 -->
            <Border Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,0,0,12"
                    Cursor="Hand"
                    MouseLeftButtonDown="MemoCard_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="{DynamicResource AccentBrush}" Margin="0,0,14,0">
                        <TextBlock Text="M" FontSize="22" FontWeight="Bold"
                                   FontFamily="Microsoft YaHei" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="备忘录" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="记录创作灵感与待办事项"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text=">" FontFamily="Microsoft YaHei" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <TextBlock Text="更多工具即将上线..." FontSize="12"
                       Foreground="{DynamicResource BorderBrush}"
                       Margin="0,20,0,0" TextAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
