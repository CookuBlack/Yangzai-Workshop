<Window x:Class="YangzaiWorkshop.Views.CropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁剪头像 - 拖拽方框选取区域" Width="500" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 裁剪区域 -->
        <Border Grid.Row="0" ClipToBounds="True" Margin="0,0,0,12">
            <Grid>
                <Image x:Name="SourceImage" Stretch="Uniform"
                       MouseLeftButtonDown="Image_MouseDown"
                       MouseMove="Image_MouseMove"
                       MouseLeftButtonUp="Image_MouseUp"/>
                <Canvas x:Name="CropCanvas" IsHitTestVisible="False">
                    <Rectangle x:Name="CropRect" Stroke="White" StrokeThickness="2"
                               Fill="Transparent" StrokeDashArray="6,3"/>
                </Canvas>
            </Grid>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消" Width="80" Height="32" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="Transparent" Foreground="Black"
                    BorderBrush="Gray" BorderThickness="1"
                    Cursor="Hand" FontSize="13"/>
            <Button Content="确定裁剪" Width="100" Height="32"
                    Click="Confirm_Click"
                    Background="#1976D2" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
