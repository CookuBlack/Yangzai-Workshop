<Window x:Class="YangzaiWorkshop.Views.CropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁剪图片" Width="640" Height="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== 标题栏 ===== -->
            <Border Grid.Row="0" Padding="16,12" CornerRadius="12,12,0,0"
                    Background="{DynamicResource CardBackgroundBrush}">
                <Grid>
                    <TextBlock Text="&#xE8A9; 裁剪图片" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Microsoft YaHei"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="&#xE711;" Width="32" Height="32"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Cursor="Hand" HorizontalAlignment="Right"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- ===== 比例预设工具栏 ===== -->
            <Border Grid.Row="1" Padding="12,10"
                    Background="{DynamicResource WindowBackgroundBrush}">
                <StackPanel>
                    <!-- 预设按钮 -->
                    <WrapPanel Margin="0,0,0,8">
                        <Button x:Name="Btn1x1" Content="1:1 方形" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="1,1"/>
                        <Button x:Name="Btn3x4" Content="3:4 竖版" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="3,4"/>
                        <Button x:Name="Btn4x5" Content="4:5 竖版" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="4,5"/>
                        <Button x:Name="Btn9x16" Content="9:16" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="9,16"/>
                        <Button x:Name="Btn16x9" Content="16:9 横版" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="16,9"/>
                        <Button x:Name="BtnFree" Content="自由裁剪" Width="72" Height="30"
                                FontSize="12" FontFamily="Microsoft YaHei"
                                Margin="0,0,4,4" Click="RatioBtn_Click" Tag="free"/>
                    </WrapPanel>

                    <!-- 尺寸 + 状态 -->
                    <WrapPanel>
                        <TextBlock Text="宽" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                        <TextBox x:Name="WInput" Width="60" Height="26" FontSize="12"
                                 TextAlignment="Center" TextChanged="SizeInput_Changed"
                                 Background="{DynamicResource WindowBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1" Padding="0"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="px  高" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,4,0"/>
                        <TextBox x:Name="HInput" Width="60" Height="26" FontSize="12"
                                 TextAlignment="Center" TextChanged="SizeInput_Changed"
                                 Background="{DynamicResource WindowBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1" Padding="0"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="px" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
                        <Border x:Name="RatioBadge" CornerRadius="4" Padding="8,2"
                                Background="{DynamicResource PrimaryLowBrush}"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock x:Name="RatioLabel" FontSize="11"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ===== 裁剪区 ===== -->
            <Grid x:Name="CropGrid" Grid.Row="2" ClipToBounds="True" Margin="12,0"
                  Background="#222" MouseWheel="CropGrid_MouseWheel">
                <Image x:Name="Img" Stretch="Uniform" IsHitTestVisible="False"/>
                <Canvas x:Name="Masks" IsHitTestVisible="False">
                    <Rectangle x:Name="MskTop"    Fill="#88000000"/>
                    <Rectangle x:Name="MskBot"    Fill="#88000000"/>
                    <Rectangle x:Name="MskLeft"   Fill="#88000000"/>
                    <Rectangle x:Name="MskRight"  Fill="#88000000"/>
                </Canvas>
                <Canvas x:Name="EventCanvas" Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp">
                    <Rectangle x:Name="Sel" Stroke="#FFF" StrokeThickness="2"
                               StrokeDashArray="6,3" Fill="Transparent"/>
                    <Rectangle x:Name="HandleTL" Width="12" Height="12" Fill="#FFF" Stroke="#333"
                               StrokeThickness="1" RadiusX="2" RadiusY="2"
                               MouseLeftButtonDown="Handle_MouseDown" Cursor="SizeNWSE"/>
                    <Rectangle x:Name="HandleTR" Width="12" Height="12" Fill="#FFF" Stroke="#333"
                               StrokeThickness="1" RadiusX="2" RadiusY="2"
                               MouseLeftButtonDown="Handle_MouseDown" Cursor="SizeNESW"/>
                    <Rectangle x:Name="HandleBL" Width="12" Height="12" Fill="#FFF" Stroke="#333"
                               StrokeThickness="1" RadiusX="2" RadiusY="2"
                               MouseLeftButtonDown="Handle_MouseDown" Cursor="SizeNESW"/>
                    <Rectangle x:Name="HandleBR" Width="12" Height="12" Fill="#FFF" Stroke="#333"
                               StrokeThickness="1" RadiusX="2" RadiusY="2"
                               MouseLeftButtonDown="Handle_MouseDown" Cursor="SizeNWSE"/>
                </Canvas>
            </Grid>

            <!-- ===== 底部按钮 ===== -->
            <Border Grid.Row="3" Padding="16,10" CornerRadius="0,0,12,12"
                    Background="{DynamicResource CardBackgroundBrush}">
                <Grid>
                    <TextBlock Text="拖拽选区移动 | 四角拖拽调整大小 | 滚轮缩放"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="80" Height="32"
                                FontSize="13" FontFamily="Microsoft YaHei"
                                Margin="0,0,8,0" Click="Cancel_Click"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button Content="确定裁剪" Width="100" Height="32"
                                FontSize="13" FontFamily="Microsoft YaHei"
                                FontWeight="SemiBold" Click="Confirm_Click"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
