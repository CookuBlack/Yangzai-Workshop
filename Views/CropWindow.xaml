<Window x:Class="YangzaiWorkshop.Views.CropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁剪头像" Width="560" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 裁剪区：同一 Grid 内叠放三层 -->
        <Grid x:Name="CropGrid" Grid.Row="0" ClipToBounds="True"
              Background="#333" MouseWheel="CropGrid_MouseWheel" Margin="0,0,0,12">
            <!-- 1. 图片 -->
            <Image x:Name="Img" Stretch="Uniform" IsHitTestVisible="False"/>
            <!-- 2. 半透遮罩 -->
            <Canvas x:Name="Masks" IsHitTestVisible="False">
                <Rectangle x:Name="MskTop"    Fill="#66000000"/>
                <Rectangle x:Name="MskBot"    Fill="#66000000"/>
                <Rectangle x:Name="MskLeft"   Fill="#66000000"/>
                <Rectangle x:Name="MskRight"  Fill="#66000000"/>
            </Canvas>
            <!-- 3. 选区框 + 鼠标事件 -->
            <Canvas x:Name="EventCanvas" Background="Transparent"
                    MouseLeftButtonDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseUp">
                <Rectangle x:Name="Sel" Stroke="White" StrokeThickness="2"
                           StrokeDashArray="6,3" Fill="Transparent"/>
            </Canvas>
        </Grid>

        <TextBlock Grid.Row="1" Text="拖拽移动选区 | 滚轮缩放选区 | 确定裁剪"
                   FontSize="11" Foreground="#888" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="取消" Width="80" Height="32" Margin="0,0,8,0"
                    Click="Cancel_Click" Background="#555555" Foreground="#EEEEEE"
                    BorderBrush="#777" BorderThickness="1" Cursor="Hand" FontSize="13"/>
            <Button Content="确定裁剪" Width="100" Height="32"
                    Click="Confirm_Click" Background="#8B4513" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
