<Window x:Class="YangzaiWorkshop.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" Height="160" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True">
    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="24,20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.25" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="14" FontWeight="Bold"
                       FontFamily="Microsoft YaHei UI" Margin="0,0,0,6"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="StatusText" FontSize="11" FontFamily="Microsoft YaHei UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>
            <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                         Value="0" Foreground="{DynamicResource PrimaryBrush}"
                         Background="{DynamicResource HoverBrush}"
                         BorderThickness="0" Margin="0,0,0,8"/>
            <TextBlock x:Name="PercentText" FontSize="10" FontFamily="Microsoft YaHei UI"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Right" Text="0%"/>
        </StackPanel>
    </Border>
</Window>
