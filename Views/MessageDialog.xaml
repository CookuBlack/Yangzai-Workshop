<Window x:Class="YangzaiWorkshop.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" MinHeight="160" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="RootBorder"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="20">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="RootShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.25" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock x:Name="TitleBlock" Grid.Row="0" FontSize="15" FontWeight="Bold"
                       FontFamily="Microsoft YaHei"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,12"/>

            <!-- 内容 -->
            <TextBlock x:Name="MessageBlock" Grid.Row="1" FontSize="13"
                       FontFamily="Microsoft YaHei"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <!-- 可选勾选框 -->
            <CheckBox x:Name="RemindCheckBox" Grid.Row="2" FontSize="11"
                      FontFamily="Microsoft YaHei" Margin="0,0,0,14"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Visibility="Collapsed"/>

            <!-- 按钮 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="取消" Width="80" Height="30"
                        FontSize="12" FontFamily="Microsoft YaHei"
                        Margin="0,0,8,0" Click="CancelBtn_Click"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button x:Name="OkBtn" Content="确定" Width="80" Height="30"
                        FontSize="12" FontFamily="Microsoft YaHei"
                        Click="OkBtn_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
