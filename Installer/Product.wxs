<!--
  Yangzai Workshop MSI 安装程序 (WiX Toolset v5)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Yangzai Workshop"
           Language="2052"
           Codepage="936"
           Manufacturer="YangzaiWorkshop"
           Version="1.0.0.0"
           UpgradeCode="E8F7A3B2-1C5D-4E89-9A2F-3D6B0C4A7E15"
           Compressed="yes">

    <SummaryInformation
        Description="小说漫剧创作桌面工作台"
        Keywords="小说;漫剧;WPF;创作"
        Manufacturer="YangzaiWorkshop" />

    <MajorUpgrade AllowDowngrades="no"
                   DowngradeErrorMessage="已安装更高版本，请先卸载后再安装此版本。" />

    <!-- 支持选择安装路径的 UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALL_FOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- 安装目录 -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALL_FOLDER" Name="YangzaiManager" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="Yangzai Workshop" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <!-- Assets 子目录 -->
    <DirectoryRef Id="INSTALL_FOLDER">
      <Directory Id="AssetsDir" Name="Assets">
        <Directory Id="AvatarDir" Name="Avatar">
          <Directory Id="AvatarMiniDir" Name="Avatar_Mini" />
        </Directory>
        <Directory Id="CarouselDir" Name="Carousel" />
        <Directory Id="IconDir" Name="Icon" />
      </Directory>
    </DirectoryRef>

    <!-- ===== 文件 ===== -->

    <!-- 根目录：EXE + DLL + JSON（.pdb 在 .msi 中会被自动跳过） -->
    <ComponentGroup Id="RootFiles" Directory="INSTALL_FOLDER">
      <Files Include="..\publish\YangzaiWorkshop.exe" />
      <Files Include="..\publish\*.dll" />
      <Files Include="..\publish\*.json" />
    </ComponentGroup>

    <!-- Assets/Avatar -->
    <ComponentGroup Id="AvatarFiles" Directory="AvatarDir">
      <Files Include="..\publish\Assets\Avatar\*.png" />
    </ComponentGroup>
    <ComponentGroup Id="AvatarMiniFiles" Directory="AvatarMiniDir">
      <Files Include="..\publish\Assets\Avatar\Avatar_Mini\*.png" />
    </ComponentGroup>

    <!-- Assets/Carousel -->
    <ComponentGroup Id="CarouselFiles" Directory="CarouselDir">
      <Files Include="..\publish\Assets\Carousel\*.mp4" />
    </ComponentGroup>

    <!-- Assets/Icon -->
    <ComponentGroup Id="IconFiles" Directory="IconDir">
      <Files Include="..\publish\Assets\Icon\Yangzai.ico" />
    </ComponentGroup>

    <!-- ===== 快捷方式 ===== -->
    <ComponentGroup Id="ShortcutComponents" Directory="INSTALL_FOLDER">
      <Component Id="DesktopSC" Guid="A1111111-BBBB-CCCC-DDDD-00000000000A">
        <Shortcut Id="DesktopShortcut" Name="Yangzai Workshop"
                  Target="[INSTALL_FOLDER]YangzaiWorkshop.exe"
                  WorkingDirectory="INSTALL_FOLDER" Directory="DesktopFolder" />
        <RegistryValue Root="HKCU" Key="Software\YangzaiManager"
                       Name="Desktop" Value="1" Type="integer" KeyPath="yes" />
      </Component>
      <Component Id="StartMenuSC" Guid="A1111111-BBBB-CCCC-DDDD-00000000000B">
        <Shortcut Id="StartMenuShortcut" Name="Yangzai Workshop"
                  Target="[INSTALL_FOLDER]YangzaiWorkshop.exe"
                  WorkingDirectory="INSTALL_FOLDER" Directory="StartMenuDir" />
        <RemoveFolder Id="RmStartMenu" Directory="StartMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\YangzaiManager"
                       Name="StartMenu" Value="1" Type="integer" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ===== 功能 ===== -->
    <Feature Id="MainFeature" Title="Yangzai Workshop"
             Description="小说漫剧创作桌面工作台"
             Level="1" AllowAdvertise="no">
      <ComponentGroupRef Id="RootFiles" />
      <ComponentGroupRef Id="AvatarFiles" />
      <ComponentGroupRef Id="AvatarMiniFiles" />
      <ComponentGroupRef Id="CarouselFiles" />
      <ComponentGroupRef Id="IconFiles" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

  </Package>
</Wix>
