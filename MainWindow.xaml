<Window x:Class="YangzaiWorkshop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yangzai Workshop"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        >

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <!-- 悬浮效果：外层透明窗口 + 大圆角 Border + 深度投影 -->
    <Border x:Name="MainBorder" CornerRadius="12"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" BlurRadius="25"
                              Opacity="0.35" Direction="315"
                              Color="#35000000"/>
        </Border.Effect>

        <!-- 自定义主题背景图（默认隐藏，ZIndex=-1 置于底层） -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 背景图片层（自定义主题时显示） -->
            <Grid x:Name="BgImageGrid" Visibility="Collapsed" ClipToBounds="True"
                  Panel.ZIndex="-1" Grid.RowSpan="2"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Image x:Name="BgImage" Stretch="UniformToFill"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- ===== 顶部标题栏 ===== -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + 标题（左对齐） -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                                Background="Transparent">
                        <Border Width="26" Height="26" CornerRadius="6"
                                VerticalAlignment="Center" Margin="16,0,8,0"
                                ClipToBounds="True">
                            <Border.Background>
                                <ImageBrush x:Name="LogoBrush" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Yangzai Workshop" FontFamily="Microsoft YaHei UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- AI 网站书签 -->
                        <Button x:Name="AiBookmarkBtn"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="AiBookmarkBtn_Click" ToolTip="常用 AI 网站"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>

                        <!-- 备忘录 -->
                        <Button Style="{StaticResource WindowControlButtonStyle}"
                                Click="MemoButton_Click" ToolTip="备忘录"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>

                        <!-- 主题切换 -->
                        <Button Style="{StaticResource WindowControlButtonStyle}"
                                Click="ThemeToggle_Click" ToolTip="切换主题（亮色 → 暗色 → 天空之蓝 → 自定义）"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="ThemeIcon" Text="&#xE706;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Margin="0,0,0,1"/>
                        </Button>

                        <!-- 最小化 -->
                        <Button Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click" ToolTip="最小化"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- 最大化 / 还原 -->
                        <Button Style="{StaticResource WindowControlButtonStyle}"
                                Click="MaximizeButton_Click" ToolTip="最大化"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="MaxIcon" Text="&#xE922;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- 关闭 -->
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click" ToolTip="关闭"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 主体区域 ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧导航栏：ListBox 驱动动画 -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="0,0,0,12" Padding="4,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="NavList" Grid.Row="0"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="NavList_SelectionChanged"
                                 Margin="0,4,0,0">

                            <ListBoxItem Tag="Home" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="首页" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Script" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="剧本管理" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Character" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="人物素材" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Video" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="视频文件" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Audio" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="音频文件" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Stats" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="平台指标" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Toolbox" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="工具箱" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>

                        <!-- 底部：个人资料 / 设置（与主导航统一动画） -->
                        <ListBox x:Name="BottomNavList" Grid.Row="1"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="BottomNavList_SelectionChanged"
                                 VerticalAlignment="Bottom" Margin="0,0,0,4">

                            <ListBoxItem Tag="Profile" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <Ellipse x:Name="ProfileAvatarEllipse" Width="24" Height="24"
                                             HorizontalAlignment="Center">
                                        <Ellipse.Fill>
                                            <ImageBrush Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="个人资料" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Settings" Style="{StaticResource NavItemStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="设置" FontSize="11" HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 主内容区 -->
                <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}"
                        CornerRadius="0,0,12,12" UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <!-- 页面内容 -->
                        <ContentControl x:Name="ContentArea" Grid.Row="0"/>

                        <!-- 底部状态栏 -->
                        <Border Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                Padding="12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="VersionText" Text="v2.0.0" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                <TextBlock x:Name="UpdateDateText" Text="2025-01-01" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Cursor="Hand" ToolTip="GitHub"
                                           MouseLeftButtonDown="GitHubLink_MouseLeftButtonDown"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- AI 网站书签弹窗 -->
            <Popup x:Name="AiBookmarkPopup" PlacementTarget="{Binding ElementName=AiBookmarkBtn}"
                   Placement="Bottom" StaysOpen="False"
                   AllowsTransparency="True" PopupAnimation="Slide">
                <Border CornerRadius="10" MinWidth="280" MaxWidth="360"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="AI 工具书签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <!-- 书签列表 -->
                        <ItemsControl x:Name="BookmarkList" Background="Transparent"
                                      PreviewMouseMove="BookmarkList_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="BookmarkList_PreviewMouseUp"
                                      MouseLeave="BookmarkList_MouseLeave">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2,0,2" Padding="6,3"
                                            Background="Transparent" CornerRadius="4"
                                            BorderBrush="Transparent" BorderThickness="2"
                                            Cursor="Hand"
                                            Loaded="ItemBorder_Loaded">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 拖拽手柄 -->
                                            <TextBlock Grid.Column="0" Text="⋮⋮" FontSize="15"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                                       IsHitTestVisible="False"/>
                                            <!-- 名称按钮 -->
                                            <Button Grid.Column="1" Content="{Binding Name}"
                                                    FontSize="13" FontFamily="Microsoft YaHei UI"
                                                    HorizontalContentAlignment="Left"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="10,6" Margin="0,0,4,0"
                                                    Click="BookmarkItem_Click"/>
                                            <!-- 删除 -->
                                            <Button Grid.Column="2" Content="✕" FontSize="10"
                                                    Width="24" Height="24" Padding="0"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Click="DeleteBookmark_Click" ToolTip="移除"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- 添加栏 -->
                        <Border Margin="0,8,0,0" Padding="8" CornerRadius="6"
                                Background="{DynamicResource WindowBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="新增书签" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBox x:Name="NewBookmarkName" FontSize="12" FontFamily="Microsoft YaHei UI"
                                         Padding="6,4"
                                         Background="{DynamicResource CardBackgroundBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         TextChanged="NewBookmarkName_TextChanged"/>
                                    <TextBlock Text="输入名称（如：ChatGPT）" FontSize="12"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0"
                                               x:Name="NamePlaceholder"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBox x:Name="NewBookmarkUrl" FontSize="12" FontFamily="Microsoft YaHei UI"
                                         Padding="6,4"
                                         Background="{DynamicResource CardBackgroundBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         TextChanged="NewBookmarkUrl_TextChanged"/>
                                    <TextBlock Text="输入网址（如：chat.openai.com）" FontSize="12"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="8,0"
                                               x:Name="UrlPlaceholder"/>
                                </Grid>
                                <Button Content="+ 添加" FontSize="12" FontFamily="Microsoft YaHei UI"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="10,4" Margin="0,0,0,2"
                                        Click="AddBookmark_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
